# Copy this file to .env.local and fill in real values
# .env.local is gitignored — never commit real secrets

# Supabase — get from: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Resend — get from: resend.com → API Keys (Day 5)
RESEND_API_KEY=re_...

# Upstash Redis — get from: upstash.com → Redis → REST API (Day 5)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
